# ============================
# Django core settings
# ============================

# Secret key for Django (must be strong and kept secret)
SECRET_KEY=replace-with-a-secure-random-string

# Debug must be disabled in production
DEBUG=False

# Deployment environment
ENV=production

# Allowed hosts (comma-separated, no spaces)
ALLOWED_HOSTS=example.com,www.example.com


# ============================
# CSRF settings
# ============================

# Trusted origins for CSRF protection (comma-separated, include scheme)
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com


# ============================
# Database settings
# ============================

# Database engine: sqlite or mysql
DB_ENGINE=mysql

# MySQL connection details
DB_NAME=exam_management
DB_USER=exam_user
DB_PASSWORD=strong-db-password
DB_HOST=db.example.com
DB_PORT=4000


# ============================
# Email settings
# ============================

# Replace with real email backend in production
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend or smtp.example.com
DEFAULT_FROM_EMAIL=noreply@example.com
